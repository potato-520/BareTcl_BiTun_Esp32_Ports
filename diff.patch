+                .len = len,
+                .type = HTTPD_WS_TYPE_TEXT
+            };
+            httpd_ws_send_frame_async(ws_server_handle, ws_active_fd, &ws_pkt);
+        }
+        xSemaphoreGive(ws_mutex);
+    }
+}
 
