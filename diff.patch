+static void ws_send_text(const char *text, size_t len) {
+    if (ws_mutex == NULL) return;
+    if (xSemaphoreTake(ws_mutex, portMAX_DELAY) == pdTRUE) {
+        if (ws_server_handle != NULL && ws_active_fd != -1) {
+            httpd_ws_frame_t ws_pkt = {
